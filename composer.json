{
    "name": "danplaton4/tenancy-bundle",
    "description": "Multi-tenant Symfony bundle — zero boilerplate, zero leaks.",
    "type": "symfony-bundle",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "symfony/cache": "^6.4||^7.0",
        "symfony/config": "^6.4||^7.0",
        "symfony/console": "^6.4||^7.0",
        "symfony/dependency-injection": "^6.4||^7.0",
        "symfony/event-dispatcher": "^6.4||^7.0",
        "symfony/http-foundation": "^6.4||^7.0",
        "symfony/http-kernel": "^6.4||^7.0"
    },
    "require-dev": {
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/migrations": "^3.9",
        "doctrine/orm": "^3.3",
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^6.4||^7.0",
        "symfony/messenger": "^6.4||^7.0",
        "symfony/phpunit-bridge": "^6.4||^7.0"
    },
    "suggest": {
        "doctrine/dbal": "Required for database drivers (^4.4)",
        "doctrine/doctrine-bundle": "Required for Doctrine integration (^2.13)",
        "doctrine/orm": "Required for Tenant entity (^3.3)",
        "symfony/messenger": "Required for tenant context preservation across async message processing (^6.4||^7.0)"
    },
    "autoload": {
        "psr-4": {
            "Tenancy\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tenancy\\Bundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Tenancy\\Bundle\\TenancyBundle": ["all"]
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
